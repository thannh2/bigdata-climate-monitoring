{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://bigdata-climate-monitoring.local/schemas/air_quality_normalized.schema.json",
    "title": "NormalizedAirQualityRecord",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "event_id",
        "source",
        "region",
        "city",
        "station_id",
        "latitude",
        "longitude",
        "event_time",
        "ingestion_time",
        "data_version"
    ],
    "properties": {
        "event_id": {
            "type": "string",
            "format": "uuid"
        },
        "source": {
            "type": "string",
            "enum": [
                "aqicn",
                "iqair",
                "open-meteo",
                "openweathermap"
            ]
        },
        "region": {
            "type": "string",
            "enum": [
                "bac",
                "trung",
                "nam"
            ]
        },
        "city": {
            "type": "string"
        },
        "station_id": {
            "type": "string"
        },
        "latitude": {
            "type": "number"
        },
        "longitude": {
            "type": "number"
        },
        "event_time": {
            "type": "string",
            "format": "date-time"
        },
        "ingestion_time": {
            "type": "string",
            "format": "date-time"
        },
        "aqi": {
            "type": [
                "number",
                "null"
            ]
        },
        "quality_level": {
            "type": [
                "string",
                "null"
            ]
        },
        "pm25": {
            "type": [
                "number",
                "null"
            ]
        },
        "pm10": {
            "type": [
                "number",
                "null"
            ]
        },
        "co": {
            "type": [
                "number",
                "null"
            ]
        },
        "no2": {
            "type": [
                "number",
                "null"
            ]
        },
        "so2": {
            "type": [
                "number",
                "null"
            ]
        },
        "o3": {
            "type": [
                "number",
                "null"
            ]
        },
        "data_version": {
            "type": "string",
            "const": "v1"
        }
    }
}